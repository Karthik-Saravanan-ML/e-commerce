# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/bookverse

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=30d

# Cloudinary — required for production
STORAGE_MODE=auto

# Easiest: paste full URL from Cloudinary Dashboard → API Keys
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@your_cloud_name

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# If API key lacks Upload permission, create unsigned preset named "bookverse" in Cloudinary
CLOUDINARY_UPLOAD_PRESET=bookverse
API_PUBLIC_URL=http://localhost:5000

# Supabase
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_BUCKET=bookverse-files

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
# Local testing without Razorpay (development only)
ALLOW_DEV_PAYMENTS=true

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# Email (NodeMailer / Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=BookVerse <no-reply@bookverse.com>

# Twilio (SMS/Call reminders)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE=+1xxxxxxxxxx

# LibreTranslate (self-hosted or public)
LIBRE_TRANSLATE_URL=https://libretranslate.com/translate
LIBRE_TRANSLATE_API_KEY=your_key

# Admin initial credentials (for seed)
ADMIN_EMAIL=admin@bookverse.com
ADMIN_PASSWORD=Admin@1234
